{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "downmark",
  "version": "0.1.0",
  "identifier": "io.github.byun.downmark",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "downmark",
        "acceptFirstMouse": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 22
        },
        "width": 1180,
        "height": 820,
        "minWidth": 820,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "A tiny markdown editor for opening and editing plain .md files.",
    "copyright": "Copyright (c) 2026 Byun",
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown"],
        "name": "Markdown Document",
        "description": "Markdown note",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
